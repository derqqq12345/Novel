# ═══════════════════════════════════════════════════════════════════════════════
# AI 장편소설 생성 플랫폼 - 환경변수 설정
# ═══════════════════════════════════════════════════════════════════════════════
# 이 파일을 .env로 복사하고 실제 값으로 수정하세요.
# 주의: .env 파일은 절대 Git에 커밋하지 마세요!

# ─── 환경 설정 ────────────────────────────────────────────────────────────────
DEBUG=true
ENVIRONMENT=development

# ─── Qwen AI API ──────────────────────────────────────────────────────────────
# Qwen API 키 (필수) - https://dashscope.aliyun.com 에서 발급
QWEN_API_KEY=your-qwen-api-key-here
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=novel_platform
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/novel_platform

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ─── Qdrant 벡터 DB ───────────────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── JWT 인증 ─────────────────────────────────────────────────────────────────
# 프로덕션에서는 반드시 강력한 랜덤 키로 변경하세요!
JWT_SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Celery 비동기 작업 ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── CORS ─────────────────────────────────────────────────────────────────────
# 쉼표로 구분된 허용 오리진 목록
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── 데이터베이스 커넥션 풀 ───────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ─── 속도 제한 ────────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ─── 서비스 포트 ──────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=5173
